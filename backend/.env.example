# Server
SERVER_PORT=8080
GIN_MODE=debug

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=vpn_manager
DB_SSLMODE=disable

# Public endpoint clients dial (used as a fallback for client configs)
DEFAULT_ENDPOINT=vpn.example.com

# CORS (comma separated, * for all)
CORS_ALLOW_ORIGINS=http://localhost:5173

# Auth (bootstrap super-admin)
# Users live in the database with Argon2id-hashed passwords. On first boot, when
# the users table is empty, these credentials seed a single super-admin user.
# After that, manage users/roles/permissions via the API (/users, /roles,
# /permissions). With AUTH_PASSWORD empty and no users yet, no admin is created
# and the API stays locked. Change the bootstrap password after first login.
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
# Secret used to sign session tokens. Use a long random string in production
# (e.g. `openssl rand -hex 32`). If left empty, an ephemeral secret is generated
# on startup and all sessions reset whenever the server restarts.
AUTH_TOKEN_SECRET=
# Session lifetime in hours (default 24).
AUTH_TOKEN_TTL_HOURS=24

# VPN runtime execution (OpenVPN, L2TP/IPsec, SSTP, PPTP)
# Single safety toggle for every non-WireGuard protocol. When false (the
# default) the Apply endpoints validate the request and return 412 without
# touching the host. Set to true ONLY on a host that already has the required
# daemons installed (docker for OpenVPN; strongswan + xl2tpd for L2TP/IPsec;
# sstpd for SSTP; pptpd for PPTP). When true, Apply writes the rendered config
# files and runs the provisioning + iptables/NAT commands.
VPN_EXECUTION_ENABLED=false
# Directory the runtime config files are written under when execution is enabled.
VPN_RUNTIME_ROOT=/var/lib/vpn-manager
# Master key (>= 16 chars) used to encrypt OpenVPN CA/server/client certificate
# material at rest. Required before saving any OpenVPN certificate/key material.
OPENVPN_SECRET_MASTER_KEY=
